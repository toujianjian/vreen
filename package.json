{
  "name": "vreen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "VREEN - 3D Game Display System. A holographic-grade 3D model inspector and showcase for indie game developers and 3D artists.",
  "author": "toujianjian",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "engine:sync": "node scripts/sync-engine-package.mjs",
    "engine:build": "cd packages/engine && npm run build",
    "engine:typecheck": "cd packages/engine && npm run typecheck",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm:dev\" \"wait-on http://localhost:5173 && cross-env VREEN_DEV=1 electron .\"",
    "electron:build": "npm run build && electron-builder --win --x64",
    "electron:build:dir": "npm run build && electron-builder --win --x64 --dir",
    "vreen": "node scripts/vreen-cli.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/orbitron": "^5.2.8",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "draco3d": "^1.5.7",
    "fflate": "^0.8.3",
    "framer-motion": "^11.11.7",
    "i18next": "^26.3.4",
    "lucide-react": "^0.453.0",
    "postprocessing": "^6.36.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.27.0",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.toujianjian.vreen",
    "productName": "VREEN",
    "copyright": "Copyright © 2026 toujianjian",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toujianjian/vreen.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/toujianjian/vreen/issues"
  },
  "homepage": "https://github.com/toujianjian/vreen#readme"
}
