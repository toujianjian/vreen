{
  "name": "@vreen/engine",
  "version": "0.1.0",
  "description": "Self-developed WebGL2 engine kernel: scene graph, ECS, PBR, IBL, post-FX, physics. Zero runtime deps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,

  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "build:bundle": "esbuild src/index.ts --bundle --format=esm --target=es2022 --outfile=dist/index.js --platform=browser --sourcemap --external:draco3d",
    "build": "npm run build:types && npm run build:bundle",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "draco3d": "^1.5.7"
  },
  "peerDependenciesMeta": {
    "draco3d": {
      "optional": true
    }
  },
  "keywords": [
    "webgl2",
    "engine",
    "3d",
    "ecs",
    "scene-graph",
    "pbr",
    "ibl",
    "post-processing",
    "physics"
  ],
  "license": "MIT"
}
